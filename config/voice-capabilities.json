{
  "meta": {
    "name": "Voice Capability Profiles",
    "version": "1.0",
    "description": "Voice-specific tag effectiveness ratings for smart enhancement"
  },

  "capability_schema": {
    "voice_id": "string - ElevenLabs voice ID",
    "voice_name": "string - Display name",
    "language": "string - Primary language",
    "gender": "male|female|neutral",
    "age_range": "child|young|adult|mature|elderly",
    "base_characteristics": {
      "energy": "1-5 scale",
      "warmth": "1-5 scale", 
      "clarity": "1-5 scale",
      "expressiveness": "1-5 scale"
    },
    "tag_effectiveness": {
      "tag_name": {
        "rating": "1-5 (1=poor, 5=excellent)",
        "notes": "optional notes"
      }
    },
    "recommended_genres": ["list of genres"],
    "not_recommended_for": ["genres to avoid"],
    "notes": "general notes about the voice"
  },

