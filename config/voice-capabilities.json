  "tag_fallback_rules": {
    "description": "When a tag has low effectiveness for a voice, suggest alternatives",
    "fallbacks": {
      "shouting": ["urgently", "firmly", "loudly"],
      "laughs harder": ["laughs", "chuckles"],
      "wheezing": ["laughs", "breathlessly"],
      "giggling": ["chuckles", "laughs softly"],
      "crying": ["voice breaking", "shakily", "tearfully"],
      "screaming": ["shouting", "desperately", "urgently"]
    }
  },

  "auto_detection_hints": {
    "description": "Clues to auto-detect voice capabilities from ElevenLabs metadata",
    "rules": [
      {
        "if": "preview contains laughter",
        "then": "likely good at laugh tags"
      },
      {
        "if": "labeled as 'calm' or 'soothing'",
        "then": "likely good at whispers, softly; weak at shouting, angry"
      },
      {
        "if": "labeled as 'energetic' or 'upbeat'",
        "then": "likely good at excited, happy, laughs; may struggle with subtle emotions"
      },
      {
        "if": "labeled as 'professional' or 'authoritative'",
        "then": "likely good at matter-of-factly, determined; may struggle with playful tags"
      }
    ]
  }
