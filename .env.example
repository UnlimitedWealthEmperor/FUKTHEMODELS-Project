# ElevenLabs API Key (required)
ELEVENLABS_API_KEY=your-api-key-here

# OpenAI API Key (for enhancement - optional)
OPENAI_API_KEY=your-openai-key-here

# Anthropic API Key (alternative for enhancement - optional)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Server Configuration
PORT=8000
HOST=0.0.0.0

# Environment
ENV=development

# Google Cloud Storage (optional - for persistent audio storage)
# If not configured, audio files will be stored locally
GCS_BUCKET_NAME=your-bucket-name
GCS_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Google Sheets Database (optional - for persistent history metadata)
# Create a new Google Sheet and share it with your service account email
# The ID is in the URL: https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
GOOGLE_SHEETS_ID=your-spreadsheet-id-here
